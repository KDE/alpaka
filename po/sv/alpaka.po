#, kde-format
msgid "Ollama server URL"
msgstr "Ollama-serverwebbadress"

#: src/apps/qml/OllamaSettingsPage.qml:30
#, kde-format
msgid "Advanced Parameters"
msgstr "Avancerade parametrar"

#: src/apps/qml/OllamaSettingsPage.qml:34
#, kde-format
msgid "Context size"
msgstr "Sammanhangsstorlek"

#: src/apps/qml/OllamaSettingsPage.qml:42
#, kde-format
msgid "Repeat penalty lookback tokens"
msgstr "Upprepa straff för tillbakablickande symboler"

#: src/apps/qml/OllamaSettingsPage.qml:43
#, kde-format
msgid ""
"How far back to look for repeated tokens (0 = disabled, -1 = context size)"
msgstr ""
"Hur långt tillbaka upprepade symboler letas efter (0 = inaktiverat, -1 = "
"sammanhangsstorlek)"

#: src/apps/qml/OllamaSettingsPage.qml:51
#, kde-format
msgid "Repeat penalization factor [scaled x10]"
msgstr "Upprepa straffaktor (skalad x10)"

#: src/apps/qml/OllamaSettingsPage.qml:52
#, kde-format
msgid "Sets how strongly to penalize repetitions (0 = disabled)"
msgstr "Ställer in hur starkt upprepningar straffas (0 = inaktiverat)"

#: src/apps/qml/OllamaSettingsPage.qml:61
#, kde-format
msgid "Temperature [scaled x10]"
msgstr "Temperatur (skalad x10]"

#: src/apps/qml/OllamaSettingsPage.qml:62
#, kde-format
msgid "Higher = more creative/random, lower = more focused/deterministic"
msgstr "Högre = mer kreativ/slumpmässig, lägre = mer fokuserad/deterministisk"

#: src/apps/qml/OllamaSettingsPage.qml:71
#, kde-format
msgid "Seed (-1 = random)"
msgstr "Frö (-1 = slumpmässigt)"

#: src/apps/qml/OllamaSettingsPage.qml:79
#, kde-format
msgid "Maximum tokens to predict (-1 = unlimited)"
msgstr "Maximalt antal symboler att prediktera (-1 = obegränsat)"

#: src/apps/qml/OllamaSettingsPage.qml:87
#, kde-format
msgid "Top K"
msgstr "Topp K"

#: src/apps/qml/OllamaSettingsPage.qml:95
#, kde-format
msgid "Top P [scaled x100]"
msgstr "Topp P [skalat x100]"

#: src/apps/qml/OllamaSettingsPage.qml:96
#, kde-format
msgid ""
"Nucleus sampling – consider tokens that make up this cumulative probability"
msgstr ""
"Kärnsampling: ta hänsyn till symboler som utgör den här kumulativa "
"sannolikheten"

#: src/apps/qml/OllamaSettingsPage.qml:105
#, kde-format
msgid "Min P [scaled x10]"
msgstr "Min P [skalat x10]"

#: src/apps/qml/OllamaSettingsPage.qml:106
#, kde-format
msgid ""
"Minimum probability a token must have to be considered, relative to the "
"probability of the most likely token"
msgstr ""
"Minimal sannolikhet att en symbol måste tas hänsyn till, i förhållande till "
"sannolikheten för den mest sannolika symbolen"

#: src/apps/qml/OllamaSettingsPage.qml:115
#, kde-format
msgid "Reset to defaults"
msgstr "Återställ till standardvärden"

#: src/apps/qml/OllamaSettingsPage.qml:117
#, kde-format
msgid "Restore all settings to their recommended default values"
msgstr "Återställ alla inställningar till rekommenderade standardvärden"

